<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cinematic Smart Planner</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Segoe UI;}
body{
  height:100vh;
  display:flex;
  background:linear-gradient(135deg,#0f172a,#1e293b);
  color:#fff;
  overflow:hidden;
}

/* Background animation */
.bg{
  position:absolute;
  width:200%;
  height:200%;
  background:radial-gradient(circle at 20% 30%,#3b82f6,transparent),
             radial-gradient(circle at 80% 70%,#9333ea,transparent);
  animation:move 10s infinite alternate;
  z-index:0;
}
@keyframes move{
  from{transform:translate(0,0);}
  to{transform:translate(-100px,-100px);}
}

/* Layout */
.container{
  position:relative;
  z-index:2;
  display:flex;
  width:100%;
}

/* Sidebar */
.sidebar{
  width:220px;
  backdrop-filter:blur(20px);
  background:rgba(255,255,255,0.1);
  padding:20px;
}

.sidebar h2{margin-bottom:20px;}
.sidebar button{
  width:100%;
  margin:10px 0;
  padding:10px;
  border:none;
  background:#3b82f6;
  color:white;
  cursor:pointer;
  border-radius:8px;
}

/* Main */
.main{
  flex:1;
  padding:20px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
}

/* Cards */
.card{
  backdrop-filter:blur(15px);
  background:rgba(255,255,255,0.1);
  padding:20px;
  border-radius:15px;
  box-shadow:0 10px 30px rgba(0,0,0,0.3);
  transition:transform 0.2s;
}

/* 3D hover */
.card:hover{
  transform:rotateY(5deg) rotateX(5deg) scale(1.03);
}

/* Task */
input{
  padding:10px;
  width:70%;
  border:none;
  border-radius:5px;
}

button.add{
  padding:10px;
  background:#22c55e;
  border:none;
  color:white;
}

ul{list-style:none;margin-top:10px;}
li{
  display:flex;
  justify-content:space-between;
  margin-top:5px;
}

.done{text-decoration:line-through;color:#aaa;}

/* Timer */
.timer{
  font-size:40px;
  text-align:center;
}

/* Progress */
.bar{
  height:20px;
  background:#444;
  border-radius:10px;
}
.fill{
  height:100%;
  width:0%;
  background:#3b82f6;
  border-radius:10px;
}

/* Theme */
.light{
  background:#f1f5f9;
  color:#111;
}

</style>
</head>

<body>

<div class="bg"></div>

<div class="container">

<div class="sidebar">
  <h2>🎬 Planner</h2>
  <button onclick="toggleTheme()">Toggle Theme</button>
</div>

<div class="main">

<div class="card">
<h3>📝 Tasks</h3>
<input id="taskInput" placeholder="New task">
<button class="add" onclick="addTask()">Add</button>
<ul id="list"></ul>
</div>

<div class="card">
<h3>⏱️ Timer</h3>
<div class="timer" id="timer">25:00</div>
<button onclick="start()">Start</button>
<button onclick="reset()">Reset</button>
</div>

<div class="card">
<h3>📊 Progress</h3>
<div class="bar"><div class="fill" id="fill"></div></div>
</div>

</div>
</div>

<script>
let tasks=JSON.parse(localStorage.getItem("tasks"))||[];

function save(){localStorage.setItem("tasks",JSON.stringify(tasks));}

function render(){
  let list=document.getElementById("list");
  list.innerHTML="";
  let done=0;

  tasks.forEach((t,i)=>{
    if(t.done)done++;
    let li=document.createElement("li");
    li.innerHTML=`
      <span onclick="toggle(${i})" class="${t.done?'done':''}">
      ${t.text}</span>
      <button onclick="del(${i})">❌</button>`;
    list.appendChild(li);
  });

  let percent=tasks.length?(done/tasks.length)*100:0;
  document.getElementById("fill").style.width=percent+"%";
}

function addTask(){
  let input=document.getElementById("taskInput");
  if(!input.value)return;
  tasks.push({text:input.value,done:false});
  input.value="";
  save();render();
}

function del(i){tasks.splice(i,1);save();render();}
function toggle(i){tasks[i].done=!tasks[i].done;save();render();}

/* Timer */
let time=1500,intv;
function start(){
  clearInterval(intv);
  intv=setInterval(()=>{
    time--;
    let m=Math.floor(time/60),s=time%60;
    document.getElementById("timer").innerText=
    `${m}:${s<10?'0':''}${s}`;
    if(time<=0)clearInterval(intv);
  },1000);
}
function reset(){time=1500;document.getElementById("timer").innerText="25:00";}

/* Theme */
function toggleTheme(){
  document.body.classList.toggle("light");
}

render();
</script>

</body>
</html>