<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Ultra Pro Smart Planner</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Segoe UI;}
body{
  height:100vh;
  overflow:hidden;
  color:#fff;
  background:#0f172a;
}

/* Cinematic gradient */
.bg{
  position:absolute;
  width:200%;
  height:200%;
  background:
    radial-gradient(circle at 20% 30%,#3b82f6,transparent),
    radial-gradient(circle at 80% 70%,#9333ea,transparent),
    radial-gradient(circle at 50% 50%,#22c55e,transparent);
  animation:move 12s infinite alternate;
}
@keyframes move{
  from{transform:translate(0,0);}
  to{transform:translate(-120px,-120px);}
}

/* Layout */
.container{
  position:relative;
  z-index:2;
  display:flex;
  height:100%;
}

/* Sidebar */
.sidebar{
  width:240px;
  backdrop-filter:blur(20px);
  background:rgba(255,255,255,0.1);
  padding:20px;
}
.sidebar h2{margin-bottom:20px;}
.sidebar button{
  width:100%;
  margin:8px 0;
  padding:10px;
  border:none;
  border-radius:8px;
  background:#3b82f6;
  color:white;
  cursor:pointer;
}

/* Main */
.main{
  flex:1;
  padding:20px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px;
}

/* Card */
.card{
  background:rgba(255,255,255,0.1);
  backdrop-filter:blur(20px);
  padding:20px;
  border-radius:15px;
  transition:transform 0.2s;
  box-shadow:0 15px 40px rgba(0,0,0,0.3);
}

/* 3D tilt */
.card:hover{
  transform:rotateY(8deg) rotateX(6deg) scale(1.03);
}

/* Task */
input,select{
  padding:8px;
  margin:5px 0;
}
button.add{
  padding:8px;
  background:#22c55e;
  border:none;
  color:white;
}

ul{list-style:none;margin-top:10px;}
li{
  display:flex;
  justify-content:space-between;
  margin-top:6px;
}
.done{text-decoration:line-through;color:#aaa;}

/* Timer */
.timer{
  font-size:35px;
  text-align:center;
}

/* Circular progress */
.circle{
  width:120px;height:120px;
  border-radius:50%;
  background:conic-gradient(#3b82f6 0%,#444 0%);
  display:flex;align-items:center;justify-content:center;
  margin:auto;
}

/* Calendar */
.calendar{
  display:grid;
  grid-template-columns:repeat(7,1fr);
  gap:5px;
}
.day{
  padding:8px;
  text-align:center;
  background:rgba(255,255,255,0.1);
  border-radius:5px;
}

/* Light theme */
.light{
  background:#f1f5f9;
  color:#111;
}
</style>
</head>

<body>

<div class="bg"></div>

<div class="container">

<div class="sidebar">
  <h2>🎬 Ultra Planner</h2>
  <button onclick="toggleTheme()">🌙 Theme</button>
  <button onclick="toggleSound()">🎵 Sound</button>
</div>

<div class="main">

<!-- Tasks -->
<div class="card">
<h3>📝 Tasks</h3>
<input id="taskInput" placeholder="Task">
<select id="priority">
  <option>Low</option>
  <option>Medium</option>
  <option>High</option>
</select>
<button class="add" onclick="addTask()">Add</button>
<ul id="list"></ul>
</div>

<!-- Timer -->
<div class="card">
<h3>⏱️ Pomodoro</h3>
<div class="timer" id="timer">25:00</div>
<button onclick="start()">Start</button>
<button onclick="breakTime()">Break</button>
</div>

<!-- Progress -->
<div class="card">
<h3>📊 Progress</h3>
<div class="circle" id="circle"><span id="percent">0%</span></div>
</div>

<!-- Calendar -->
<div class="card">
<h3>📅 Calendar</h3>
<div class="calendar" id="calendar"></div>
</div>

</div>
</div>

<audio id="bgm" loop>
  <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3">
</audio>

<script>
let tasks=JSON.parse(localStorage.getItem("tasks"))||[];

function save(){localStorage.setItem("tasks",JSON.stringify(tasks));}

function render(){
  let list=document.getElementById("list");
  list.innerHTML="";
  let done=0;

  tasks.forEach((t,i)=>{
    if(t.done)done++;
    let li=document.createElement("li");
    li.innerHTML=`
      <span onclick="toggle(${i})" class="${t.done?'done':''}">
      ${t.text} (${t.priority})</span>
      <button onclick="del(${i})">❌</button>`;
    list.appendChild(li);
  });

  let percent=tasks.length?(done/tasks.length)*100:0;
  document.getElementById("percent").innerText=Math.round(percent)+"%";
  document.getElementById("circle").style.background=
    `conic-gradient(#3b82f6 ${percent}%,#444 ${percent}%)`;
}

function addTask(){
  let t=document.getElementById("taskInput");
  let p=document.getElementById("priority").value;
  if(!t.value)return;
  tasks.push({text:t.value,priority:p,done:false});
  t.value="";
  save();render();
}

function del(i){tasks.splice(i,1);save();render();}
function toggle(i){tasks[i].done=!tasks[i].done;save();render();}

/* Timer */
let time=1500,intv;
function start(){
  clearInterval(intv);
  intv=setInterval(()=>{
    time--;
    let m=Math.floor(time/60),s=time%60;
    document.getElementById("timer").innerText=
    `${m}:${s<10?'0':''}${s}`;
    if(time<=0)clearInterval(intv);
  },1000);
}
function breakTime(){
  time=300;
}

/* Calendar */
function loadCalendar(){
  let cal=document.getElementById("calendar");
  for(let i=1;i<=30;i++){
    let d=document.createElement("div");
    d.className="day";
    d.innerText=i;
    cal.appendChild(d);
  }
}

/* Theme */
function toggleTheme(){
  document.body.classList.toggle("light");
}

/* Sound */
function toggleSound(){
  let audio=document.getElementById("bgm");
  if(audio.paused) audio.play();
  else audio.pause();
}

loadCalendar();
render();
</script>

</body>
</html>
